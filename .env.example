NODE_ENV=development

# 필수에 가까운 기본 설정
DRY_RUN=true
ENABLE_LIVE_TRADING=false
TRADING_KILL_SWITCH=false
SELECTION_MODE=allowlist
TRADE_TARGETS=USDC
RISK_PROFILE=balanced
MARKET_DATA_MODE=auto
QUOTE_CURRENCY=KRW

# 코인원 인증 정보
COINONE_ACCESS_TOKEN=
COINONE_SECRET_KEY=

# 알림 / 보고
SLACK_WEBHOOK_URL=
GITHUB_REPOSITORY=
GITHUB_CREATE_ISSUES=false

# 에이전트 판단(고급)
AGENT_DECISION_PROVIDER=mock
AGENT_PROVIDER_ENDPOINT=
AGENT_PROVIDER_API_KEY=
AGENT_PROVIDER_MODEL=

# 선택형 고급 설정 (비워두면 RISK_PROFILE 기준 자동 계산)
AUTO_SELECTION_UNIVERSE=
MAX_SELECTED_ASSETS=
EXCLUDED_TARGETS=
DEFAULT_STRATEGY_PROFILE=
STABLECOIN_TARGETS=
STRATEGY_PROFILE_OVERRIDES=
MAX_ORDER_KRW=
MAX_POSITION_PER_ASSET_KRW=
MAX_DAILY_BUY_KRW=
MAX_TRADES_PER_DAY=
MAX_OPEN_POSITIONS=
MAX_PORTFOLIO_EXPOSURE_PCT=
MIN_CASH_RESERVE_KRW=
COOLDOWN_MINUTES=
BUY_FRACTION_OF_CASH=
SELL_FRACTION_OF_POSITION=

# 시스템 / 출력 경로 (보통 수정 불필요)
EXECUTION_APPROVAL_WINDOW_SECONDS=300
COINONE_CLI_PATH=
COINONE_CLI_TIMEOUT_MS=15000
COINONE_CLI_BASE_URL=
AGENT_DECISION_OUTPUT_DIR=artifacts/agent-decision
EXECUTION_PREVIEW_OUTPUT_DIR=artifacts/execution-preview
AGENT_PROVIDER_PROMPT_VERSION=phase-4
AGENT_PROVIDER_TEMPERATURE=
AGENT_PROVIDER_TIMEOUT_MS=20000
AGENT_PROVIDER_FALLBACK_TO_MOCK=false
SLACK_NOTIFY_ROUTINE_PREVIEW=false
SLACK_NOTIFY_ROUTINE_DRY_RUN=false
SLACK_NOTIFY_APPROVAL_NEEDED=true
SLACK_NOTIFY_ACTION_NEEDED=true
SLACK_NOTIFY_DAILY_REPORT=true
SLACK_NOTIFY_MONTHLY_REPORT=true
SLACK_NOTIFY_LIVE_SUBMIT=true
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
REPORT_OUTPUT_DIR=reports/generated
